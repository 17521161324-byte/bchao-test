# B 超语音测试平台 — 环境变量配置

APP_NAME=bchao-test
APP_ENV=production

HOST=0.0.0.0
PORT=8000

# 数据库
DATABASE_URL=sqlite:///./data/bchao.db

# 文件存储（Windows 路径示例）
DATA_DIR=./data
UPLOAD_DIR=./uploads
RECORDINGS_DIR=C:/bchao-test/backend/data/recordings

# 本地 ASR
LOCAL_ASR_URL=http://172.16.10.142:50000

# 默认模型
DEFAULT_ASR_PROVIDER=local

# CORS（允许前端访问）
CORS_ORIGINS=["http://localhost","http://localhost:5173"]

# 日志
LOG_LEVEL=INFO
